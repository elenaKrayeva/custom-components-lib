{
  "name": "custom-components-lib",
  "version": "0.1.0",
  "description": "React UI components library (TypeScript, Webpack, CSS Modules).",
  "license": "MIT",
  "author": "Alena",
  "homepage": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourname/your-ui-lib.git"
  },
  "bugs": {
    "url": "https://github.com/yourname/your-ui-lib/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky install",
    "test": "echo \"(todo) add jest+rtl\" && exit 0",
    "storybook": "echo \"(todo) add storybook\" && exit 0",
    "storybook:build": "echo \"(todo) build storybook\" && exit 0"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "mini-css-extract-plugin": "^2.9.4",
    "prettier": "^3.6.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.9.2",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {},
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "library",
    "typescript",
    "webpack",
    "css-modules"
  ]
}
